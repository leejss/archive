---
import { getCollection } from "astro:content";
import Root from "@/layout/root.astro";

const notes = (await getCollection("note")).sort(
  (a, b) =>
    new Date(b.data.publishedAt).getTime() -
    new Date(a.data.publishedAt).getTime(),
);

function dateCode(date: Date) {
  const yyyy = date.getFullYear();
  const mm = String(date.getMonth() + 1).padStart(2, "0");
  const dd = String(date.getDate()).padStart(2, "0");
  return `${yyyy}${mm}${dd}`;
}
---

<Root title="">
  <main class="container">
    <ul class="post-list" aria-label="Notes">
      {notes.map((post) => (
        <li class="post-item">
          <time datetime={post.data.publishedAt.toISOString()} class="post-date">
            {dateCode(post.data.publishedAt)}
          </time>
          <a href={`/notes/${post.id}`} class="post-link">
            {post.data.title}
          </a>
        </li>
      ))}
    </ul>
  </main>
</Root>

<style>
  .post-item {
    font-size: 1rem;
  }

  .post-date {
    color: var(--default-muted-color);
    font-family: var(--font-mono);
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.7rem;
  }

  .post-item {
    align-items: baseline;
    column-gap: 1.2rem;
    display: grid;
    grid-template-columns: 9ch minmax(0, 1fr);
  }

  .post-link {
    color: var(--default-link-color);
    min-width: 0;
    overflow-wrap: anywhere;
  }

  .post-link:focus-visible {
    outline: 1px solid var(--default-border-hover-color);
    outline-offset: 0.2rem;
  }

  .post-date {
    display: inline-block;
    width: 9ch;
  }
</style>
