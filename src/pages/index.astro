---
import { getCollection } from "astro:content";
import Root from "@/layout/root.astro";
import { formatPublishedAt } from "@/utils/common";

const notes = (await getCollection("note")).sort(
  (a, b) =>
    new Date(b.data.publishedAt).getTime() -
    new Date(a.data.publishedAt).getTime(),
);
---

<Root title="">
  <main class="container">
    <header class="terminal-header">
      <p>STATUS: ONLINE</p>
      <p>WRITING: {notes.length} NOTES</p>
    </header>
    <p class="section-divider">~~~</p>
    <p class="section-label">WRITING:</p>
    <ul class="post-list">
      {
        notes.map((post) => {
          return (
            <li class="post-item">
              <p class="post-title-line">
                <span class="post-prefix">- [</span>
                <a href={`/notes/${post.id}`} class="post-link">
                  {post.data.title}
                </a>
                <span class="post-prefix">]</span>
                {post.data.aiGenerated && <span class="ai-badge"> [AI]</span>}
              </p>
              {post.data.publishedAt && (
                <time
                  datetime={post.data.publishedAt.toISOString()}
                  class="post-date"
                >
                  {" "}({formatPublishedAt(post.data.publishedAt)})
                </time>
              )}
            </li>
          );
        })
      }
    </ul>
  </main>
</Root>

<style>
  .terminal-header {
    display: grid;
    gap: 0.3rem;
    padding-top: 1.75rem;
  }

  .terminal-header p,
  .section-label,
  .post-item {
    font-size: 1rem;
  }

  .section-label {
    margin-bottom: 0.35rem;
    font-weight: 700;
    color: var(--default-text-color);
  }

  .ai-badge {
    color: var(--default-muted-color);
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.7rem;
  }

  .post-title-line {
    align-items: baseline;
    display: flex;
    min-width: 0;
  }

  .post-link {
    color: var(--default-link-color);
    min-width: 0;
    overflow-wrap: anywhere;
  }

  .post-link:focus-visible {
    outline: 1px solid var(--default-border-hover-color);
    outline-offset: 0.2rem;
  }

  .post-prefix {
    color: var(--default-muted-color);
  }

  .post-date {
    display: block;
    color: var(--default-muted-color);
    padding-left: 2.1rem;
  }
</style>
