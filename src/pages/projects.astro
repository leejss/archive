---
import Root from "@/layout/root.astro";
import { projects } from "../data/projects";
---

<Root title="Projects">
  <main class="container">
    <p class="section-divider">~~~</p>
    <section class="project-section" aria-labelledby="projects-title">
      <h1 id="projects-title" class="section-label">PROJECTS:</h1>
      <ul class="project-list">
        {
          projects.map((project) => (
            <li class="project-item">
              <p>
                <span class="muted">- [</span>
                <a
                  href={project.webUrl ?? project.githubUrl ?? "#"}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {project.name}
                </a>
                <span class="muted">]</span>
              </p>
              <p class="project-summary">{project.summary}</p>
              <p class="project-links">
                {project.webUrl && (
                  <a href={project.webUrl} target="_blank" rel="noopener noreferrer">
                    [web]
                  </a>
                )}
                {project.githubUrl && (
                  <a href={project.githubUrl} target="_blank" rel="noopener noreferrer">
                    [github]
                  </a>
                )}
              </p>
            </li>
          ))
        }
      </ul>
    </section>
  </main>
</Root>

<style>
  .project-section {
    padding-top: 1.75rem;
  }

  .section-label {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.35rem;
  }

  .project-list {
    display: grid;
    gap: 1.3rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .project-item {
    display: grid;
    gap: 0.2rem;
  }

  .project-summary {
    color: var(--default-text-color);
    padding-left: 1.5rem;
  }

  .project-links {
    display: flex;
    gap: 0.7rem;
    padding-left: 1.5rem;
  }

  .muted {
    color: var(--default-muted-color);
  }
</style>
