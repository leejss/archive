---
import Root from "@/layout/root.astro";
import { projects } from "../data/projects";
---

<Root title="Projects">
  <main class="container">
    <section class="project-section" aria-labelledby="projects-title">
      <h1 id="projects-title" class="section-label">Projects</h1>
      <div class="project-list">
        {
          projects.map((project) => (
            <article class="project-item">
              <a
                href={project.webUrl ?? project.githubUrl ?? "#"}
                target="_blank"
                rel="noopener noreferrer"
              >
                {project.name}
              </a>
              <p class="project-summary">{project.summary}</p>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</Root>

<style>
  .project-section {
  }

  .section-label {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.35rem;
  }

  .project-list {
    display: grid;
    gap: 1rem;
    margin-top: 1.4rem;
  }

  .project-item {
    display: grid;
    gap: 0.2rem;
  }

  .project-summary {
    color: var(--default-muted-color);
  }
</style>
