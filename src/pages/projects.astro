---
import Root from "@/layout/root.astro";
import { projects } from "../data/projects";
---

<Root useSlotContainer={false}>
  <main class="project-container">
    <div class="scroll-viewport">
      <ul class="project-list">
        {
          projects.map((project, index) => (
            <li class="project-item" data-index={index}>
              <a href={project.webUrl ?? project.githubUrl ?? "#"} class="project-link">
                {project.name}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
      <aside class="project-card" aria-live="polite" aria-atomic="true">
        <div class="project-card__links" aria-label="Project links">
          <a
            class="project-card__icon-link"
            href={projects[0]?.webUrl ?? ""}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Website"
            data-kind="web"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm7.93 9h-3.18c-.14-1.36-.48-2.67-1.03-3.89A8.03 8.03 0 0 1 19.93 11ZM12 4c.93 0 2.27 1.9 3.02 7H8.98C9.73 5.9 11.07 4 12 4ZM4.07 13h3.18c.14 1.36.48 2.67 1.03 3.89A8.03 8.03 0 0 1 4.07 13ZM7.25 11H4.07a8.03 8.03 0 0 1 4.6-5.02A15.7 15.7 0 0 0 7.25 11Zm9.5 0c-.22-1.58-.61-3.11-1.18-4.45C16.97 7.1 18.69 8.85 19.93 11h-3.18ZM7.25 13h9.5c-.22 1.58-.61 3.11-1.18 4.45-.6 1.4-1.3 2.45-2.08 2.55h-2.98c-.78-.1-1.48-1.15-2.08-2.55-.57-1.34-.96-2.87-1.18-4.45Zm-3.18 0h3.18c.22 1.58.61 3.11 1.18 4.45C7.03 16.9 5.31 15.15 4.07 13Zm12.68 5.02c.42-.96.72-1.99.9-3.02h2.28a8.03 8.03 0 0 1-3.18 3.02ZM7.15 15c.18 1.03.48 2.06.9 3.02A8.03 8.03 0 0 1 4.87 15h2.28Z" />
            </svg>
          </a>
          <a
            class="project-card__icon-link"
            href={projects[0]?.githubUrl ?? ""}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            data-kind="github"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.7c-2.77.6-3.35-1.16-3.35-1.16-.45-1.14-1.1-1.45-1.1-1.45-.9-.62.07-.61.07-.61 1 .07 1.52 1.03 1.52 1.03.89 1.53 2.34 1.09 2.91.83.09-.65.35-1.09.63-1.34-2.21-.25-4.54-1.11-4.54-4.95 0-1.09.39-1.99 1.03-2.69-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.03a9.6 9.6 0 0 1 5 0c1.9-1.3 2.74-1.03 2.74-1.03.55 1.38.2 2.4.1 2.65.64.7 1.03 1.6 1.03 2.69 0 3.85-2.34 4.7-4.57 4.95.36.31.68.92.68 1.85v2.74c0 .26.18.58.69.48A10 10 0 0 0 12 2Z" />
            </svg>
          </a>
        </div>
        <p class="project-card__summary">{projects[0]?.summary ?? ""}</p>
      </aside>
  </main>
</Root>

<style>
  :root {
    --item-height: 9vh;
    --gap: 2vh;

    @media (min-width: 768px) {
      --item-height: 13vh;
      --gap: 4vh;
    }
  }

  .project-container {
    height: 100vh;
    width: 100%;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    background: var(--default-bg-color);
    color: var(--default-text-color);
    transition:
      background-color 0.3s,
      color 0.3s;
  }

  .scroll-viewport {
    flex: 1;
    overflow-y: scroll;
    perspective: 1000px;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    position: relative;
  }

  .scroll-viewport::-webkit-scrollbar {
    display: none;
  }

  .project-list {
    list-style: none;
    /* Center the list vertically with huge padding */
    padding: 50vh 0;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--gap);
    transform-style: preserve-3d;
    width: fit-content;
  }

  .project-item {
    height: var(--item-height);
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    opacity: 0;
    will-change: transform, opacity;
  }

  .project-link {
    /* Fluid typography adjusted for slimmer rows */
    font-size: clamp(2rem, 8vw, 6.5rem);
    font-weight: 700;
    text-decoration: none;
    color: var(--default-text-color);
    white-space: nowrap;
    text-align: center;
    transition: color 0.3s;
    line-height: 1.1;
  }

  .project-item[data-active="true"] .project-link {
    color: var(--default-text-color);
    text-shadow: 0 0.5vh 2vh rgba(0, 0, 0, 0.15);
  }

  .project-card {
    position: absolute;
    right: 2rem;
    bottom: 2rem;
    /* Responsive card width */
    width: min(420px, 85vw);
    padding: clamp(1.25rem, 2vh, 2rem);
    border-radius: 16px;
    background: rgba(0, 0, 0, 0.25);
    backdrop-filter: blur(16px);
    color: var(--default-text-color);
    box-shadow: 0 2vh 5vh rgba(0, 0, 0, 0.2);
    display: flex;
    flex-direction: column;
    gap: 1.5vh;
    pointer-events: none;
    z-index: 10;
  }

  /* Mobile adjustments for the card */
  @media (max-width: 768px) {
    .project-card {
      right: 50%;
      transform: translateX(50%);
      bottom: 1vh;
      width: 90vw;
    }
  }

  .project-card__eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: 0.75rem;
    opacity: 0.6;
  }

  .project-card__title {
    font-size: clamp(1.25rem, 4vw, 1.8rem);
    margin: 0;
  }

  .project-card__links {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    pointer-events: auto;
  }

  .project-card__icon-link {
    width: 2.25rem;
    height: 2.25rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.12);
    color: var(--default-text-color);
    box-shadow: 0 0.75rem 1.5rem rgba(0, 0, 0, 0.15);
    pointer-events: auto;
    transition:
      transform 0.2s ease,
      background-color 0.2s ease,
      opacity 0.2s ease;
  }

  .project-card__icon-link:hover {
    transform: translateY(-1px);
    background: rgba(255, 255, 255, 0.18);
  }

  .project-card__icon-link svg {
    width: 1.25rem;
    height: 1.25rem;
    display: block;
    fill: currentColor;
  }

  .project-card__summary {
    margin: 0;
    opacity: 0.8;
    line-height: 1.5;
    font-size: clamp(0.9rem, 3vw, 1rem);
  }

  .project-card__meta {
    margin: 0;
    display: grid;
    gap: 0.5rem;
  }

  .project-card__meta-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.9rem;
    opacity: 0.8;
  }

  .project-card__tags {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .project-card__tags li {
    font-size: 0.75rem;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.12);
  }
</style>

<script>
  import Lenis from "lenis";
  import { projects } from "../data/projects";

  const CONFIG = {
    THRESHOLDS: {
      ENTER: 0.6,
      EXIT: 0.9,
    },

    TIMING_MS: {
      HOLD: 300,
      SNAP_IDLE: 140,
    },

    ANIMATION: {
      SNAP_DURATION_S: 0.75,
      SNAP_EPSILON: 0.12,
      SNAP_MAX_DISTANCE: 1.2,

      // Visual factors
      OPACITY_FACTOR: {
        DESKTOP: 0.35,
        MOBILE: 0.6,
      },
      VISIBILITY_CUTOFF: {
        DESKTOP: 2.5,
        MOBILE: 1.6,
      },
      SCALE_FACTOR: 0.1,
      MIN_SCALE: 0.8,

      ITEM_SPACING_RATIO: 0.11,
    },
    EASING: {
      SNAP: (t: number) => 1 - Math.pow(1 - t, 3),
      LENIS: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
    },
  } as const;

  interface ItemMetric {
    el: HTMLElement;
    center: number;
    height: number;
  }

  interface VisualState {
    scale: number;
    opacity: number;
    normalizedDist: number;
  }

  interface ScrollState {
    status: "IDLE" | "SNAPPING" | "PENDING";
    activeIndex: number;
    pendingIndex: number;
    pendingSince: number;
    lastNearestDistance: number;
    lastNearestIndex: number;
    isDesktop: boolean;
    itemSpacing: number;
    viewportHeight: number;
    viewportCenter: number;
  }

  function measureMetrics(items: HTMLElement[]): ItemMetric[] {
    return items.map((item) => ({
      el: item,
      height: item.offsetHeight,
      center: item.offsetTop + item.offsetHeight / 2,
    }));
  }

  function calculateItemSpacing(viewportHeight: number): number {
    return viewportHeight * CONFIG.ANIMATION.ITEM_SPACING_RATIO;
  }

  function calculateVisuals(
    distAbs: number,
    itemSpacing: number,
    isDesktop: boolean,
  ): VisualState {
    const normalizedDist = distAbs / itemSpacing;
    const opacityFactor = isDesktop
      ? CONFIG.ANIMATION.OPACITY_FACTOR.DESKTOP
      : CONFIG.ANIMATION.OPACITY_FACTOR.MOBILE;
    const visibilityCutoff = isDesktop
      ? CONFIG.ANIMATION.VISIBILITY_CUTOFF.DESKTOP
      : CONFIG.ANIMATION.VISIBILITY_CUTOFF.MOBILE;

    let opacity = 1 - normalizedDist * opacityFactor;
    if (normalizedDist >= visibilityCutoff) opacity = 0;
    if (opacity < 0) opacity = 0;

    let scale = 1 - normalizedDist * CONFIG.ANIMATION.SCALE_FACTOR;
    if (scale < CONFIG.ANIMATION.MIN_SCALE) scale = CONFIG.ANIMATION.MIN_SCALE;

    return { scale, opacity, normalizedDist };
  }

  /**
   * Finds the nearest item index based on current scroll position.
   */
  function findNearestIndex(
    metrics: ItemMetric[],
    contentCenter: number,
    itemSpacing: number,
  ): { index: number; distance: number; distances: number[] } {
    let nearestIndex = 0;
    let nearestDistance = Number.POSITIVE_INFINITY;
    const distances: number[] = [];

    metrics.forEach((metric, index) => {
      const distAbs = Math.abs(metric.center - contentCenter);
      const normalized = distAbs / itemSpacing;
      distances[index] = normalized;

      if (normalized < nearestDistance) {
        nearestDistance = normalized;
        nearestIndex = index;
      }
    });

    return { index: nearestIndex, distance: nearestDistance, distances };
  }

  type CardElements = {
    title: HTMLElement | null;
    summary: HTMLElement | null;
    webLink: HTMLAnchorElement | null;
    githubLink: HTMLAnchorElement | null;
  };

  function renderCard(elements: CardElements, projectIndex: number) {
    const project = projects[projectIndex];
    if (!project) return;

    elements.title && (elements.title.textContent = project.name);
    elements.summary && (elements.summary.textContent = project.summary);

    if (elements.webLink) {
      if (project.webUrl) {
        elements.webLink.href = project.webUrl;
        elements.webLink.style.display = "inline-flex";
        elements.webLink.removeAttribute("aria-disabled");
      } else {
        elements.webLink.removeAttribute("href");
        elements.webLink.style.display = "none";
        elements.webLink.setAttribute("aria-disabled", "true");
      }
    }

    if (elements.githubLink) {
      if (project.githubUrl) {
        elements.githubLink.href = project.githubUrl;
        elements.githubLink.style.display = "inline-flex";
        elements.githubLink.removeAttribute("aria-disabled");
      } else {
        elements.githubLink.removeAttribute("href");
        elements.githubLink.style.display = "none";
        elements.githubLink.setAttribute("aria-disabled", "true");
      }
    }
  }

  function renderItemVisuals(
    metrics: ItemMetric[],
    contentCenter: number,
    state: ScrollState,
  ) {
    metrics.forEach((metric, i) => {
      const distAbs = Math.abs(metric.center - contentCenter);
      const { scale, opacity } = calculateVisuals(
        distAbs,
        state.itemSpacing,
        state.isDesktop,
      );

      metric.el.style.transform = `scale(${scale})`;
      metric.el.style.opacity = opacity.toString();
    });
  }

  function updateActiveStateAttributes(
    items: HTMLElement[],
    prevIndex: number,
    newIndex: number,
  ) {
    if (prevIndex >= 0 && items[prevIndex]) {
      items[prevIndex].removeAttribute("data-active");
    }
    if (newIndex >= 0 && items[newIndex]) {
      items[newIndex].setAttribute("data-active", "true");
    }
  }

  function setupProjectScroll() {
    const viewport = document.querySelector<HTMLElement>(".scroll-viewport");
    const projectList = document.querySelector<HTMLElement>(".project-list");
    const items = Array.from(
      document.querySelectorAll<HTMLElement>(".project-item"),
    );
    const cardElements = {
      title: document.querySelector<HTMLElement>(".project-card__title"),
      summary: document.querySelector<HTMLElement>(".project-card__summary"),
      webLink: document.querySelector<HTMLAnchorElement>(
        ".project-card__icon-link[data-kind=\"web\"]",
      ),
      githubLink: document.querySelector<HTMLAnchorElement>(
        ".project-card__icon-link[data-kind=\"github\"]",
      ),
    } as const;

    if (
      !viewport ||
      !projectList
      // !Object.values(cardElements).every((el) => el)
    ) {
      console.warn("ProjectScrollManager: Required elements missing");
      return;
    }

    let state: ScrollState = {
      status: "IDLE",
      activeIndex: -1,
      pendingIndex: -1,
      pendingSince: 0,
      lastNearestDistance: Infinity,
      lastNearestIndex: 0,
      isDesktop: window.innerWidth >= 768,
      itemSpacing: 0,
      viewportHeight: 0,
      viewportCenter: 0,
    };

    let metrics: ItemMetric[] = [];
    let snapTimer = 0;

    const updateLayout = () => {
      const rect = viewport.getBoundingClientRect();
      state.viewportHeight = rect.height;
      state.viewportCenter = rect.height / 2;
      state.isDesktop = window.innerWidth >= 768;
      state.itemSpacing = calculateItemSpacing(state.viewportHeight);
      metrics = measureMetrics(items);
    };

    const setActiveIndex = (index: number) => {
      if (index === state.activeIndex) return;

      updateActiveStateAttributes(items, state.activeIndex, index);
      state.activeIndex = index;
      renderCard(cardElements, index);
    };

    const snapToIndex = (index: number) => {
      const metric = metrics[index];
      if (!metric) return;

      const offset = -(state.viewportHeight / 2 - metric.height / 2);

      state.status = "SNAPPING";

      lenis.scrollTo(metric.el, {
        offset,
        duration: CONFIG.ANIMATION.SNAP_DURATION_S,
        easing: CONFIG.EASING.SNAP,
        lock: true,
        onComplete: () => {
          state.status = "IDLE";
          setActiveIndex(index);
        },
      });
    };

    const processScrollLogic = (time: number, contentCenter: number) => {
      const {
        index: nearestIndex,
        distance: nearestDistance,
        distances,
      } = findNearestIndex(metrics, contentCenter, state.itemSpacing);

      state.lastNearestIndex = nearestIndex;
      state.lastNearestDistance = nearestDistance;

      const activeDist =
        state.activeIndex >= 0
          ? (distances[state.activeIndex] ?? Infinity)
          : Infinity;

      const canSwitch =
        state.activeIndex === -1 || activeDist >= CONFIG.THRESHOLDS.EXIT;

      // Pending/Switch Logic
      if (canSwitch && nearestDistance <= CONFIG.THRESHOLDS.ENTER) {
        if (state.pendingIndex !== nearestIndex) {
          state.pendingIndex = nearestIndex;
          state.pendingSince = time;
          state.status = "PENDING";
        }

        if (time - state.pendingSince >= CONFIG.TIMING_MS.HOLD) {
          setActiveIndex(nearestIndex);
          state.pendingIndex = -1;
          state.status = "IDLE";
        }
      } else {
        state.pendingIndex = -1;
        if (state.status === "PENDING") state.status = "IDLE";
      }
    };

    const scheduleSnap = () => {
      window.clearTimeout(snapTimer);
      snapTimer = window.setTimeout(() => {
        if (state.status === "SNAPPING" || items.length === 0) return;

        const activeDist =
          state.activeIndex >= 0
            ? Math.abs(
                metrics[state.activeIndex].center -
                  (lenis.scroll + state.viewportCenter),
              ) / state.itemSpacing
            : Infinity;

        const canSwitch =
          state.activeIndex === -1 || activeDist >= CONFIG.THRESHOLDS.EXIT;
        const targetIndex = canSwitch
          ? state.lastNearestIndex
          : state.activeIndex;

        if (targetIndex < 0) return;

        if (state.lastNearestDistance <= CONFIG.ANIMATION.SNAP_EPSILON) return;
        if (state.lastNearestDistance > CONFIG.ANIMATION.SNAP_MAX_DISTANCE)
          return;

        if (canSwitch && targetIndex !== state.activeIndex) {
          setActiveIndex(targetIndex);
        }
        snapToIndex(targetIndex);
      }, CONFIG.TIMING_MS.SNAP_IDLE);
    };

    const lenis = new Lenis({
      wrapper: viewport,
      content: projectList,
      duration: 1.2,
      easing: CONFIG.EASING.LENIS,
      orientation: "vertical",
      gestureOrientation: "vertical",
      smoothWheel: true,
    });

    updateLayout();

    window.addEventListener("resize", () => {
      updateLayout();
      if (state.activeIndex !== -1) {
        snapToIndex(state.activeIndex);
      }
    });

    projectList.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      const item = target.closest(".project-item");
      if (!item) return;

      const anchor = target.closest("a");
      if (anchor) e.preventDefault();

      const indexAttr = item.getAttribute("data-index");
      const index = indexAttr ? parseInt(indexAttr, 10) : NaN;

      if (Number.isFinite(index)) {
        state.pendingIndex = -1;
        snapToIndex(index);
      }
    });

    lenis.on("scroll", () => {
      if (state.status !== "SNAPPING") {
        scheduleSnap();
      }
    });

    function loop(time: number) {
      lenis.raf(time);
      const contentCenter = lenis.scroll + state.viewportCenter;
      renderItemVisuals(metrics, contentCenter, state);
      processScrollLogic(time, contentCenter);
      requestAnimationFrame(loop);
    }

    requestAnimationFrame(loop);
  }

  setupProjectScroll();
</script>
