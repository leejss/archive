---
import { getCollection, render } from "astro:content";
import Root from "@/layout/root.astro";

export async function getStaticPaths() {
  const notes = await getCollection("note");
  const paths = notes.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
  return paths;
}
const { post } = Astro.props;
const { Content } = await render(post);
const { title, publishedAt } = post.data;
---

<Root title={title}>
  <article class="container">
    <a class="back-link" href="/">[notes]</a>
    <p class="section-divider">~~~</p>
    <header class="header">
      <p class="section-label">NOTE:</p>
      <h1 class="title">{title}</h1>
      <div class="meta">
        {
          publishedAt && (
            <span>
              PUBLISHED:{" "}
              <time datetime={publishedAt.toISOString()}>
                {publishedAt.toLocaleDateString("ko-KR", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </time>
            </span>
          )
        }
        {post.data.aiGenerated && <span>AI: GENERATED</span>}
      </div>
    </header>
    <p class="section-divider">~~~</p>
    <div class="markdown-content">
      <Content />
    </div>
  </article>
</Root>

<style>
  .back-link {
    display: inline-block;
    margin-top: 1.75rem;
    font-weight: 700;
  }

  .header {
    display: grid;
    gap: 0.4rem;
  }

  .section-label,
  .header .title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--default-text-color);
  }

  .meta {
    display: grid;
    gap: 0.2rem;
    color: var(--default-muted-color);
    font-size: 0.95rem;
  }
</style>
