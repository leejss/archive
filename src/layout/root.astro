---
import { SITE } from "@/config";
import "../styles/globals.css";
import ThemeSetting from "@/components/theme-setting.astro";

interface Props {
  title?: string;
  useSlotContainer?: boolean;
}

const { title, useSlotContainer = true } = Astro.props;
const siteLabel = SITE.title.toUpperCase();
const getTitle = () => {
  if (title) {
    return `${SITE.title} | ${title}`;
  }
  return SITE.title;
};
---

<html lang={SITE.defaultLanguage}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={SITE.description} />
    <meta name="author" content={SITE.author} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={SITE.baseURL} />
    <meta property="og:title" content={getTitle()} />
    <meta property="og:description" content={SITE.description} />
    <meta property="og:image" content={`${SITE.baseURL}/og-image.png`} />
    <meta property="og:locale" content={SITE.defaultLanguage} />
    <meta property="og:site_name" content={SITE.title} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={SITE.baseURL} />
    <meta name="twitter:title" content={getTitle()} />
    <meta name="twitter:description" content={SITE.description} />
    <meta name="twitter:image" content={`${SITE.baseURL}/og-image.png`} />
    <link
      rel="preload"
      href="/fonts/AtkinsonHyperlegible-Regular.ttf"
      as="font"
      type="font/ttf"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/AtkinsonHyperlegible-Bold.ttf"
      as="font"
      type="font/ttf"
      crossorigin
    />
    <title>{getTitle()}</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.22/dist/katex.min.css"
      integrity="sha384-5TcZemv2l/9On385z///+d7MSYlvIEw9FuZTIdZ14vJLqWphw7e7ZPuOiCHJcFCP"
      crossorigin="anonymous"
    />
    <script is:inline>
      (function () {
        function getInitialTheme() {
          const savedTheme = localStorage.getItem("blog-theme");
          return savedTheme || "dark";
        }

        const theme = getInitialTheme();
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
  </head>
  <body>
    <nav class="site-navigation" aria-label="Primary">
      <div class="nav-content">
        <a href="/" class="site-title">{siteLabel}<span class="cursor"></span></a>
        <div class="nav-links">
          <a href="/" class="nav-link">notes</a>
          <a href="/projects" class="nav-link">projects</a>
          <ThemeSetting />
        </div>
      </div>
    </nav>
    {
      useSlotContainer ? (
        <div class="slot-container">
          <slot />
        </div>
      ) : (
        <slot />
      )
    }
  </body>
</html>

<style>
  .site-navigation {
    padding: 2.5rem 0 0;
    box-sizing: border-box;
  }

  .nav-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    width: min(100% - 2rem, 82ch);
    margin-left: clamp(1rem, 5%, 3rem);
    margin-right: auto;
  }

  .nav-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }

  .site-title,
  .nav-link {
    display: inline-flex;
    align-items: baseline;
    color: var(--default-text-color);
    text-decoration: none;
    font-weight: 700;
    font-size: 1rem;
  }

  .nav-link::before {
    content: "[";
    color: var(--default-muted-color);
  }

  .nav-link::after {
    content: "]";
    color: var(--default-muted-color);
  }

  .site-title:hover,
  .nav-link:hover {
    color: var(--default-link-color);
  }

  .cursor {
    display: inline-block;
    width: 0.65em;
    height: 1em;
    margin-left: 0.45em;
    background: var(--default-text-color);
    transform: translateY(0.14em);
    animation: blink 1.1s steps(1, end) infinite;
  }

  .slot-container {
    min-height: 100vh;
  }

  @keyframes blink {
    50% {
      opacity: 0;
    }
  }

  @media (max-width: 640px) {
    .site-navigation {
      padding-top: 1.25rem;
    }

    .nav-link {
      font-size: 0.95rem;
    }
  }
</style>
